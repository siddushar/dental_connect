<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="card shadow-sm">
        <div class="card-body p-4 p-md-5">
					<p class="text-uppercase text-muted small mb-2">Step 1 of 2</p>
          <h1 class="h3 mb-3">Upload your CV</h1>
          <p class="text-muted">We will automatically fill in as much of your candidate profile as possible. You can review and edit everything before saving.</p>

          <% if @document&.errors&.any? %>
            <div class="alert alert-danger"><%= @document.errors.full_messages.to_sentence %></div>
          <% end %>

          <%= form_with model: @document, url: candidate_onboarding_path, multipart: true do |form| %>
            <div class="border rounded p-4 bg-light mb-3">
              <%= form.label :file, "CV file", class: "form-label fw-semibold" %>
              <%= form.file_field :file, class: "form-control", accept: ".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document", required: true %>
              <div class="form-text">PDF, DOC, or DOCX. Maximum <%= CandidateDocument::MAX_FILE_SIZE / 1.megabyte %> MB.</div>
            </div>

            <div class="form-check mb-4">
              <%= form.check_box :consent_accepted, class: "form-check-input", required: true %>
              <%= form.label :consent_accepted, "I agree that my CV and profile information may be processed to create and improve my candidate profile.", class: "form-check-label" %>
            </div>

            <div class="d-flex gap-2">
              <%= form.submit "Analyze CV", class: "btn btn-primary", data: { disable_with: "Processing CV..." } %>
            </div>
          <% end %>

          <div class="mt-3">
            <%= button_to "Continue manually", manual_candidate_onboarding_path, method: :post, class: "btn btn-outline-secondary" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
