<div class="border rounded p-3 mb-3" data-nested-form-target="item">
  <%= experience_form.hidden_field :_destroy, value: "0" %>
  <div class="row g-3">
    <div class="col-md-6"><%= experience_form.label :job_title, class: "form-label" %><%= experience_form.text_field :job_title, class: "form-control" %></div>
    <div class="col-md-6"><%= experience_form.label :company_name, class: "form-label" %><%= experience_form.text_field :company_name, class: "form-control" %></div>
    <div class="col-md-6"><%= experience_form.label :start_date, class: "form-label" %><%= experience_form.date_field :start_date, class: "form-control" %></div>
    <div class="col-md-6"><%= experience_form.label :end_date, class: "form-label" %><%= experience_form.date_field :end_date, class: "form-control" %></div>
  </div>
  <div class="mt-3"><%= experience_form.label :responsibilities, class: "form-label" %><%= experience_form.text_area :responsibilities, rows: 3, class: "form-control" %></div>
  <div class="form-check mt-3"><%= experience_form.check_box :current_job, class: "form-check-input" %><%= experience_form.label :current_job, "Current job", class: "form-check-label" %></div>
  <button type="button" class="btn btn-outline-danger btn-sm mt-3" data-action="nested-form#remove">Remove work experience</button>
</div>
