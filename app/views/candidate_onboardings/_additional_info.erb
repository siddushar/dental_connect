<section class="card mb-3">
  <div class="card-body">
    <h2 class="h5 mb-3">Additional information</h2>
    <div class="mb-3"><%= form.label :professional_summary, class: "form-label" %><%= form.text_area :professional_summary, rows: 4, class: "form-control" %></div>
    <div class="mb-3"><%= form.label :motivation, "Motivation for employer", class: "form-label" %><%= form.text_area :motivation, rows: 4, class: "form-control" %></div>
    <div><%= form.label :internal_notes, "Internal notes for recruitment team", class: "form-label" %><%= form.text_area :internal_notes, rows: 3, class: "form-control" %></div>
  </div>
</section>
